# .env.example — 로컬 개발용 환경변수 예시
# 실제 사용 시: 이 파일을 .env로 복사하고 실제 키를 입력하세요.
# .env 파일은 .gitignore에 포함되어 GitHub에 올라가지 않습니다.

# Anthropic API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Finnhub API 키 (https://finnhub.io → Dashboard → API Keys)
# 무료 티어: 60 req/min, 미국 주식 검색·시세·일봉 스파크라인 지원
FINNHUB_API_KEY=

# 아침 자동 브리핑(Vercel Cron)용 인증 시크릿 — 임의의 랜덤 문자열로 직접 생성해서 넣으세요.
# (예: openssl rand -hex 24) Vercel이 cron 호출 시 Authorization: Bearer 헤더로 자동 첨부하며,
# api/briefing-cron.js가 이 값과 일치하는 요청만 처리합니다. Production 환경에도 등록해야
# 실제 예약 실행(vercel.json의 crons)이 동작합니다.
CRON_SECRET=

# FRED(Federal Reserve Economic Data) API 키 (https://fred.stlouisfed.org/docs/api/api_key.html 에서 발급)
# 브리핑 탭 "매크로 현황" 섹션(CPI/기준금리/실업률)용 — api/macro.js
FRED_API_KEY=
